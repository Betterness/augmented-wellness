{
  "version": 1,
  "runtime_name": "betterx",
  "owner_agent": "main",
  "operator_agent": "main",
  "worker_agent": "",
  "workspace": "~/.betterx/workspace",
  "model": "provider/fast-general-model",
  "model_roles": {
    "candidate_reader": {
      "primary": "provider/platform-context-model",
      "fallback": "provider/fast-general-model",
      "purpose": "Read platform-native context and identify likely post/reply/quote angles."
    },
    "writer": {
      "primary": "provider/platform-native-writer",
      "fallback": "provider/fast-general-model",
      "purpose": "Draft platform-native public text."
    },
    "mechanical_reviewer": {
      "primary": "provider/fast-review-model",
      "fallback": "provider/fast-general-model",
      "purpose": "Fast checks for numbered lists, repeated structures, capitalization, links, length, and automation tells."
    },
    "adversarial_reviewer": {
      "primary": "provider/strong-editor-model",
      "fallback": "provider/strong-general-model",
      "purpose": "Deep critique of voice, authenticity, reputation, claims, private-data leakage, and the operator-specific voice test."
    },
    "final_safety": {
      "primary": "provider/strong-safety-model",
      "fallback": "provider/strong-general-model",
      "purpose": "Final policy, medical, reputation, and action-type gate before execution."
    }
  },
  "timezone": "America/New_York",
  "delivery": {
    "channel": "telegram",
    "target": "",
    "announce": false
  },
  "x": {
    "adapter": "xurl",
    "app": "",
    "account": "",
    "real_xurl_bin": "",
    "read_enabled": false,
    "write_enabled": false,
    "allowed_actions": []
  },
  "platform_context_model": {
    "enabled": false,
    "provider_configured_in_runtime": false,
    "preferred_writer_model": "provider/platform-native-writer",
    "reasoning_writer_model": "provider/platform-native-reasoning-model",
    "note": "Optional. Use a model that understands the target social platform well, then keep a separate reviewer model for quality and safety."
  },
  "profile_sources": [
    {
      "name": "user_profile",
      "path": "./vault/01-person",
      "required": true,
      "kind": "directory"
    },
    {
      "name": "style_memory",
      "path": "./vault/02-style-memory",
      "required": true,
      "kind": "directory"
    },
    {
      "name": "source_graph",
      "path": "./vault/03-source-graph",
      "required": true,
      "kind": "directory"
    },
    {
      "name": "topic_graph",
      "path": "./vault/04-topic-graph",
      "required": true,
      "kind": "directory"
    },
    {
      "name": "social_graph",
      "path": "./vault/06-social-graph",
      "required": true,
      "kind": "directory"
    },
    {
      "name": "main_agent_memory",
      "path": "~/.betterx/workspace/MEMORY.md",
      "required": false,
      "kind": "file"
    },
    {
      "name": "main_agent_user",
      "path": "~/.betterx/workspace/USER.md",
      "required": false,
      "kind": "file"
    }
  ],
  "schedules": {
    "hourly_radar": {
      "enabled": true,
      "every": "1h"
    },
    "daily_learning": {
      "enabled": true,
      "every": "24h"
    },
    "metrics_snapshot": {
      "enabled": false,
      "every": "30m",
      "lookback": "48h",
      "source": "account timeline",
      "note": "Track recent account posts in the lookback window, not hardcoded post IDs."
    },
    "dreaming": {
      "enabled": false,
      "cron": "0 3 * * *"
    }
  },
  "autonomy": {
    "stop_all_external_actions": true,
    "allowed_action_exceptions": []
  }
}
